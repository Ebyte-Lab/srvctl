#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$ROOT_DIR/lib/common.sh"
source "$ROOT_DIR/core/logger.sh"
source "$ROOT_DIR/core/state_engine.sh"
source "$ROOT_DIR/core/backup_manager.sh"
source "$ROOT_DIR/core/executor.sh"

SRVCTL_IP=""
SRVCTL_IFACE=""
DRY_RUN="false"

positionals=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --ip)
            SRVCTL_IP="${2:-}"
            shift 2
            ;;
        --iface)
            SRVCTL_IFACE="${2:-}"
            shift 2
            ;;
        --dry-run)
            DRY_RUN="true"
            shift
            ;;
        --help|-h)
            printf '%s\n' "Usage: srvctl <domain> <module> <action> [--ip X] [--iface X] [--dry-run]"
            exit 0
            ;;
        --*)
            log_error "Unknown option: $1"
            exit 1
            ;;
        *)
            positionals+=("$1")
            shift
            ;;
    esac
done

if [[ ${#positionals[@]} -lt 3 ]]; then
    log_error "Usage: srvctl <domain> <module> <action> [--ip X] [--iface X] [--dry-run]"
    exit 1
fi

DOMAIN="${positionals[0]}"
MODULE="${positionals[1]}"
ACTION="${positionals[2]}"
MODULE_FILE="$ROOT_DIR/modules/$DOMAIN/${MODULE}.sh"
FUNCTION_NAME="${MODULE}_${ACTION}"

if [[ ! -f "$MODULE_FILE" ]]; then
    log_error "Module not found: $DOMAIN/$MODULE"
    exit 1
fi

source "$MODULE_FILE"

export SRVCTL_IP SRVCTL_IFACE DRY_RUN

if ! declare -F "$FUNCTION_NAME" >/dev/null 2>&1; then
    log_error "Action not found: $FUNCTION_NAME"
    exit 1
fi

"$FUNCTION_NAME"
